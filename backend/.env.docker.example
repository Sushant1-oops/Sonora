# Copy this to backend/.env when running via docker-compose.
# (backend/.env.example is for running the backend directly on your
# host machine, where Postgres/Redis are on localhost instead.)

PORT=5000
NODE_ENV=production

DATABASE_URL="postgresql://sonora:sonora_password@postgres:5432/sonora_db?schema=public"
REDIS_URL="redis://redis:6379"

JWT_ACCESS_SECRET="change_this_to_a_long_random_string_access"
JWT_REFRESH_SECRET="change_this_to_a_long_random_string_refresh"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

JAMENDO_CLIENT_ID="your_jamendo_client_id"
JAMENDO_API_BASE="https://api.jamendo.com/v3.0"

CLIENT_ORIGIN="http://localhost"
