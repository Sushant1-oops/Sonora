# Production environment reference for the Sonora backend.
#
# IMPORTANT: This file is NOT read automatically in production. Render
# (and most PaaS hosts) ignore .env files in your repo entirely — you
# paste these same key/value pairs into Render's dashboard under
# Environment Variables, and Render injects them as real process.env
# vars when your app starts. This file exists purely as a reference so
# you know exactly what to paste, without guessing or hunting through
# code.
#
# Never commit a real, filled-in version of this file. Keep secrets out
# of git — that's the whole point of entering them in Render's UI
# instead.

PORT=5000
NODE_ENV=production

# Neon (https://neon.tech) — copy the connection string from your
# Neon project dashboard. Keep ?sslmode=require at the end.
DATABASE_URL="postgresql://user:password@ep-something.region.aws.neon.tech/sonora_db?sslmode=require"

# Upstash (https://upstash.com) — copy the rediss:// URL (note the
# double "s" — that's what tells ioredis to use TLS). A plain redis://
# URL from Upstash will fail to connect.
REDIS_URL="rediss://default:password@something.upstash.io:6379"

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use two DIFFERENT random values — never reuse one secret for both.
JWT_ACCESS_SECRET="generate_a_unique_random_value_for_this"
JWT_REFRESH_SECRET="generate_a_different_unique_random_value_for_this"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Free at https://devportal.jamendo.com
JAMENDO_CLIENT_ID="your_jamendo_client_id"
JAMENDO_API_BASE="https://api.jamendo.com/v3.0"

# Must be the EXACT URL of your deployed frontend (e.g. Vercel), with
# no trailing slash. Required for CORS + cross-site cookies to work —
# see authController.js, which sets sameSite: 'none' in production
# specifically because frontend and backend live on different domains.
CLIENT_ORIGIN="https://your-app-name.vercel.app"
