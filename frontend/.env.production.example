# Production environment reference for the Sonora frontend.
#
# Same deal as the backend: Vercel/Netlify don't read this file. Paste
# this single variable into your hosting dashboard's Environment
# Variables section. This file is just a reference.
#
# Vite only exposes env vars prefixed with VITE_ to the browser bundle
# — that's intentional (anything without that prefix is for build-time
# tooling only and won't leak into client-side JS).

VITE_API_BASE_URL=https://your-backend-name.onrender.com/api
